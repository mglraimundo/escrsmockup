@page "/"
@using System.Text.RegularExpressions
@using MudBlazor
@implements IDisposable
@inject IJSRuntime JS
@inject IDialogService DialogService

<PageTitle>ESCRS IOL Calculator Mockup</PageTitle>

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="app-shell">
    <MudPaper Elevation="3" Square="true" Class="topbar">
        <div class="topbar-left">
            <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" />

            <img class="brand-logo"
                 src="assets/ESCRS_IOL_logo.png"
                 alt="ESCRS IOL Calculator" />
        </div>

        <div class="topbar-actions">
            <MudButton Variant="Variant.Filled"
                       Class="decimal-btn"
                       OnClick="ToggleDecimalFormat">
                DEC (@(UseCommaDecimalFormat ? "0,00" : "0.00"))
            </MudButton>

            <MudIconButton Icon="@Icons.Material.Filled.Settings" Color="Color.Inherit" OnClick="OpenSettingsDialogAsync" />
        </div>
    </MudPaper>

    <MudContainer MaxWidth="MaxWidth.False" Class="main-container">

        <MudPaper Elevation="1" Class="@BiomApiCardClass">
            <button type="button"
                    class="biomapi-card-header"
                    aria-expanded="@_isBiomApiExpanded"
                    @onclick="ToggleBiomApiPanel">
                <span class="biomapi-header-label">
                    <img class="biomapi-logo"
                         src="assets/biomapi.png"
                         alt="" />
                    <span>BiomAPI</span>
                </span>
                <MudIcon Icon="@(_isBiomApiExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                         Size="Size.Small" />
            </button>

            @if (_isBiomApiExpanded)
            {
                <div class="biomapi-tabs">
                    <div class="biomapi-tab-list" role="tablist" aria-label="BiomAPI input method">
                        @BiomApiTabButton("Upload", 0)
                        @BiomApiTabButton("BiomPIN", 1)
                        @BiomApiTabButton("History", 2)
                    </div>

                    <div class="biomapi-placeholder @(HasVisibleBiomApiStatus ? "has-status" : null)">
                        <div class="biomapi-active-panel">
                            @if (_activeBiomApiTab == 0)
                            {
                                <div class="biomapi-panel upload-panel">
                                    <button type="button"
                                            class="upload-dropzone"
                                            @onclick="LoadFromUploadAsync">
                                        <MudIcon Icon="@Icons.Material.Filled.UploadFile" Size="Size.Small" />
                                        <span class="upload-title">
                                            @(_selectedUploadFile ?? "Browse PDF, image or JSON")
                                        </span>
                                    </button>
                                </div>
                            }

                            @if (_activeBiomApiTab == 1)
                            {
                                <div class="biomapi-panel biompin-panel">
                                    <MudTextField T="string"
                                                  @bind-Value="_biomPinInput"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Placeholder="BiomPIN or BiomAPI URL"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Key" />

                                    <div class="biompin-actions">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Default"
                                                   StartIcon="@Icons.Material.Filled.Download"
                                                   Disabled="_isBiomApiLoading"
                                                   Class="biomapi-load-button"
                                                   OnClick="LoadFromBiomPinAsync">
                                            @(_isBiomApiLoading ? "Retrieving" : "Load")
                                        </MudButton>
                                    </div>
                                </div>
                            }

                            @if (_activeBiomApiTab == 2)
                            {
                                <div class="biomapi-panel history-panel">
                                    <MudTextField T="string"
                                                  @bind-Value="_historySearch"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Placeholder="Search by name or ID"
                                                  Adornment="Adornment.Start"
                                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                                  Class="history-search" />

                                    <div class="history-strip">
                                        <div class="history-list"
                                             onscroll="const left=this.parentElement.querySelector('.history-scroll-button.left'); const right=this.parentElement.querySelector('.history-scroll-button.right'); left?.classList.toggle('hidden', this.scrollLeft <= 2); right?.classList.toggle('hidden', this.scrollLeft + this.clientWidth >= this.scrollWidth - 2);">
                                            @foreach (var item in FilteredHistory)
                                            {
                                                <button type="button"
                                                        class="history-item"
                                                        @onclick="@(() => LoadFromHistoryAsync(item))">
                                                    <span>
                                                        <strong>@item.Initials</strong>
                                                        <span class="history-muted">(@item.PatientId)</span>
                                                    </span>
                                                    <span class="history-pin">@item.Pin</span>
                                                    <span class="history-muted">Exp @item.Expires</span>
                                                </button>
                                            }
                                        </div>
                                        <button type="button"
                                                class="history-scroll-button left hidden"
                                                aria-label="Scroll history left"
                                                onclick="this.parentElement.querySelector('.history-list').scrollBy({ left: -220, behavior: 'smooth' })">
                                            &lt;
                                        </button>
                                        <button type="button"
                                                class="history-scroll-button right"
                                                aria-label="Scroll history right"
                                                onclick="this.parentElement.querySelector('.history-list').scrollBy({ left: 220, behavior: 'smooth' })">
                                            &gt;
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                        @if (ShowBiomApiDetails && !string.IsNullOrWhiteSpace(_biomApiError))
                        {
                            <MudAlert Severity="Severity.Error"
                                      Variant="Variant.Filled"
                                      Dense="true"
                                      Class="biomapi-alert">
                                @_biomApiError
                            </MudAlert>
                        }

                        @if (ShowBiomApiDetails && _lastBiomApiLoad is not null)
                        {
                            <div class="biomapi-result-row">
                                <div class="biomapi-result">
                                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Medium" />
                                    <div class="biomapi-result-meta">
                                        <strong>BiomPIN:</strong>
                                        <span class="biomapi-pin-value">@_lastBiomApiLoad.BiomPin</span>
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Size="Size.Small"
                                                       Color="Color.Success"
                                                       Class="biomapi-copy-button"
                                                       aria-label="Copy BiomPIN"
                                                       OnClick="CopyLastBiomPinAsync" />
                                        @if (_lastBiomApiLoad.SourceLabel == "File")
                                        {
                                            <strong>File:</strong>
                                            <span>@_lastBiomApiLoad.SourceValue</span>
                                        }
                                        <strong>Expires:</strong>
                                        <span>@_lastBiomApiLoad.Expires</span>
                                    </div>
                                </div>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.OpenInNew"
                                           Class="biomapi-result-link">
                                    Open in BiomAPI
                                </MudButton>
                            </div>
                        }
                    </div>
                </div>

                <div class="biomapi-warning">
                    <MudIcon Icon="@Icons.Material.Filled.Science" Size="Size.Small" />
                    <span>BiomAPI is in technology preview. Please double-check all extracted values.</span>
                </div>
            }
        </MudPaper>

        <MudPaper Elevation="1" Class="section-card patient-card">
            <MudPaper Elevation="0" Class="patient-strip">
                <MudGrid Spacing="0">
                    <MudItem xs="12" Class="patient-field-item">
                        @PatientInput("Surgeon*", Patient.Surgeon, value => Patient.Surgeon = value)
                    </MudItem>

                    <MudItem xs="12" Class="patient-field-item">
                        @PatientInput("Patient Initials*", Patient.Initials, value => Patient.Initials = value)
                    </MudItem>

                    <MudItem xs="12" Class="patient-field-item">
                        @PatientInput("ID", Patient.Id, value => Patient.Id = value)
                    </MudItem>

                    <MudItem xs="12" Class="patient-field-item">
                        @PatientInput("Age", Patient.Age, value => Patient.Age = value, "years")
                    </MudItem>

                    <MudItem xs="12" Class="patient-field-item">
                        @GenderSelect()
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudPaper>

        <MudGrid Spacing="3">
            <MudItem xs="12" lg="6">
                @EyePanel("OD", "Right", RightEye, true)
            </MudItem>

            <MudItem xs="12" lg="6">
                @EyePanel("OS", "Left", LeftEye, false)
            </MudItem>
        </MudGrid>

        <div class="bottom-actions">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Calculate"
                       Class="action-button">
                CALCULATE
            </MudButton>

            <MudButton Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Class="action-button reset-button">
                RESET
            </MudButton>
        </div>

        <footer class="calculator-footer">
            <div class="sponsor-banner">
                <img src="@ActiveBanner"
                     alt="ESCRS sponsor banner" />
            </div>

            <div class="escrs-footer">
                <img src="assets/escrs_logo.svg"
                     alt="ESCRS" />
            </div>
        </footer>
    </MudContainer>
</div>

@code {
    private readonly string[] BannerImages = { "assets/banner1.png", "assets/banner2.png" };
    private PeriodicTimer? _bannerTimer;
    private CancellationTokenSource? _bannerTimerCancellation;
    private int _activeBannerIndex;

    private string ActiveBanner => BannerImages[_activeBannerIndex];

    protected override void OnInitialized()
    {
        _bannerTimer = new PeriodicTimer(TimeSpan.FromSeconds(10));
        _bannerTimerCancellation = new CancellationTokenSource();
        _ = RotateBannersAsync(_bannerTimerCancellation.Token);
    }

    private async Task RotateBannersAsync(CancellationToken cancellationToken)
    {
        if (_bannerTimer is null)
        {
            return;
        }

        try
        {
            while (await _bannerTimer.WaitForNextTickAsync(cancellationToken))
            {
                _activeBannerIndex = (_activeBannerIndex + 1) % BannerImages.Length;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    public void Dispose()
    {
        _bannerTimerCancellation?.Cancel();
        _bannerTimerCancellation?.Dispose();
        _bannerTimer?.Dispose();
    }

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#5140D9",
            Secondary = "#1687F2",
            Tertiary = "#FF2F7D",
            Background = "#F6F8FF",
            Surface = "#FFFFFF",
            AppbarBackground = "#5140D9",
            AppbarText = "#FFFFFF",
            TextPrimary = "#16213F",
            TextSecondary = "#64708A",
            LinesDefault = "#E2E7F3"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = new[] { "Inter", "Roboto", "Segoe UI", "Arial", "sans-serif" },
                FontSize = "0.9rem"
            },
            H6 = new H6Typography
            {
                FontWeight = "800",
                LetterSpacing = "-0.02em"
            },
            Button = new ButtonTypography
            {
                FontWeight = "800",
                TextTransform = "none"
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "10px"
        }
    };

    private List<ConstantItem> Constants = new()
    {
        new("Barrett A-Constant", "119.3537", "Barrett UII"),
        new("Cooke A-Constant", "119.3556", "Cooke K6"),
        new("EVO A-Constant", "119.1", "EVO"),
        new("Hill-RBF A-Constant", "119.3537", "Hill-RBF"),
        new("Hoffer® pACD", "5.76", "Hoffer QST"),
        new("Kane A-Constant", "119.3537", "Kane"),
        new("Pearl DGS A-Constant", "119.3537", "Pearl DGS")
    };

    private List<FormulaConfig> FormulaConfigs = new()
    {
        new("Barrett UII", true, true, true, true, true, true, true, false),
        new("Cooke K6", true, true, false, true, true, true, false, true),
        new("EVO", true, true, true, true, true, true, false, true),
        new("Hill-RBF", true, true, false, false, false, false, false, false),
        new("Hoffer QST", true, true, true, true, false, false, false, false),
        new("Kane", true, true, true, false, false, false, true, false),
        new("Pearl DGS", true, true, true, true, true, true, false, true)
    };

    private PatientModel Patient { get; } = new();

    private EyeModel RightEye { get; } = new();

    private EyeModel LeftEye { get; } = new();

    private bool UseCommaDecimalFormat;
    private bool _isBiomApiExpanded = false;
    private int _activeBiomApiTab;
    private bool _isBiomApiLoading;
    private string? _selectedUploadFile;
    private string _biomPinInput = "portion-stuff-635550";
    private string _historySearch = string.Empty;
    private string? _biomApiError;
    private BiomLoadSummary? _lastBiomApiLoad;
    private static readonly Regex BiomPinPattern = new(@"[a-z]+-[a-z]+-\d{6}", RegexOptions.IgnoreCase | RegexOptions.Compiled);
    private string BiomApiCardClass => $"section-card biomapi-card {(_isBiomApiExpanded ? "expanded" : "collapsed")}";

    private List<BiomHistoryItem> BiomApiHistory { get; } = new()
    {
        new("MMF", "10008711", "portion-stuff-635550", "05/06/26 22:30"),
        new("JDD", "12345", "win-citizen-223986", "04/06/26 17:10"),
        new("AR", "784209", "lunar-rocket-731904", "02/06/26 09:00"),
        new("LS", "445901", "paper-orbit-482910", "31/05/26 14:45"),
        new("TR", "663018", "silver-canal-119842", "30/05/26 11:20"),
        new("NV", "908114", "garden-thread-774201", "29/05/26 16:05"),
        new("HB", "551700", "quiet-harbor-390118", "27/05/26 08:35"),
        new("CP", "102884", "signal-maple-820477", "26/05/26 18:15"),
        new("EK", "770042", "ember-window-641002", "24/05/26 13:50"),
        new("DM", "319870", "north-canvas-238776", "22/05/26 10:10")
    };

    private IEnumerable<BiomHistoryItem> FilteredHistory
    {
        get
        {
            if (string.IsNullOrWhiteSpace(_historySearch))
            {
                return BiomApiHistory;
            }

            return BiomApiHistory.Where(item =>
                item.Initials.Contains(_historySearch, StringComparison.OrdinalIgnoreCase) ||
                item.PatientId.Contains(_historySearch, StringComparison.OrdinalIgnoreCase));
        }
    }

    private void ToggleBiomApiPanel()
    {
        _isBiomApiExpanded = !_isBiomApiExpanded;
    }

    private void ToggleDecimalFormat()
    {
        UseCommaDecimalFormat = !UseCommaDecimalFormat;
    }

    private async Task OpenSettingsDialogAsync()
    {
        var parameters = new DialogParameters
        {
            { "FormulaConfigs", FormulaConfigs }
        };
        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };
        var dialog = await DialogService.ShowAsync<SettingsDialog>("Settings", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false } && result.Data is List<FormulaConfig> updatedConfigs)
        {
            FormulaConfigs = updatedConfigs;
        }
    }

    private async Task LoadFromUploadAsync()
    {
        var selectedFile = _selectedUploadFile ?? "ulis-argos-1.pdf";
        _selectedUploadFile = selectedFile;

        try
        {
            await SimulateLoadAsync("File", selectedFile, "portion-stuff-635550");
        }
        finally
        {
            _selectedUploadFile = null;
        }
    }

    private async Task LoadFromBiomPinAsync()
    {
        var biomPin = ExtractBiomPin(_biomPinInput);
        if (biomPin is null)
        {
            _biomApiError = "Enter a full BiomPIN in word-word-123456 format. The numeric suffix is required to decrypt the result.";
            _lastBiomApiLoad = null;
            return;
        }

        await SimulateLoadAsync("BiomPIN", biomPin, biomPin);
    }

    private Task LoadFromHistoryAsync(BiomHistoryItem item)
    {
        _activeBiomApiTab = 1;
        _biomPinInput = item.Pin;
        return SimulateLoadAsync("BiomPIN", item.Pin, item.Pin);
    }

    private bool ShowBiomApiDetails => _activeBiomApiTab != 2;

    private bool HasVisibleBiomApiStatus =>
        ShowBiomApiDetails && (!string.IsNullOrWhiteSpace(_biomApiError) || _lastBiomApiLoad is not null);

    private async Task SimulateLoadAsync(string sourceLabel, string sourceValue, string? pin)
    {
        _isBiomApiLoading = true;
        _biomApiError = null;
        await Task.Delay(450);

        ApplySampleBiometry();
        _lastBiomApiLoad = new BiomLoadSummary(sourceLabel, sourceValue, pin ?? sourceValue, "05/06/26 22:30");

        if (!string.IsNullOrWhiteSpace(pin))
        {
            UpsertHistory(new BiomHistoryItem(Patient.Initials, Patient.Id, pin, "05/06/26 22:30"));
        }

        _isBiomApiLoading = false;
    }

    private async Task CopyLastBiomPinAsync()
    {
        if (_lastBiomApiLoad is not null)
        {
            try
            {
                await JS.InvokeVoidAsync("navigator.clipboard.writeText", _lastBiomApiLoad.BiomPin);
            }
            catch (JSException)
            {
                // Clipboard access can be blocked by browser permissions; keep the mockup usable.
            }
        }
    }

    private void ApplySampleBiometry()
    {
        Patient.Initials = "MMF";
        Patient.Id = "10008711";
        Patient.Age = "49";
        Patient.Gender = "Female";

        RightEye.AL.Value = "23.52";
        RightEye.ACD.Value = "3.18";
        RightEye.LT.Value = "4.49";
        RightEye.CCT.Value = "545";
        RightEye.WTW.Value = "11.8";
        RightEye.K1.Value = "43.25";
        RightEye.K2.Value = "44.50";

        LeftEye.AL.Value = "23.68";
        LeftEye.ACD.Value = "3.12";
        LeftEye.LT.Value = "4.56";
        LeftEye.CCT.Value = "552";
        LeftEye.WTW.Value = "11.7";
        LeftEye.K1.Value = "43.10";
        LeftEye.K2.Value = "44.35";
    }

    private void UpsertHistory(BiomHistoryItem item)
    {
        BiomApiHistory.RemoveAll(existing => existing.Pin == item.Pin);
        BiomApiHistory.Insert(0, item);
    }

    private static string? ExtractBiomPin(string value)
    {
        var match = BiomPinPattern.Match(value);
        return match.Success ? match.Value : null;
    }

    private RenderFragment BiomApiTabButton(string label, int index) => @<button type="button"
                                                                                 role="tab"
                                                                                 aria-selected="@(_activeBiomApiTab == index)"
                                                                                 class="biomapi-tab-button @(_activeBiomApiTab == index ? "active" : null)"
                                                                                 @onclick="@(() => _activeBiomApiTab = index)">
        @label
    </button>;

    private RenderFragment PatientInput(string label, string value, Action<string> valueChanged, string? unit = null) => @<div class="field-cell">
        <MudTextField T="string"
                      Label="@label"
                      Value="@value"
                      ValueChanged="@valueChanged"
                      Variant="Variant.Filled"
                      Margin="Margin.Dense"
                      Placeholder="–"
                      Clearable="true"
                      ClearIcon="@Icons.Material.Filled.Close"
                      Adornment="@(string.IsNullOrWhiteSpace(unit) ? Adornment.None : Adornment.End)"
                      AdornmentText="@unit" />
    </div>;

    private RenderFragment GenderSelect() => @<div class="field-cell">
        <MudSelect T="string"
                   Label="Gender*"
                   @bind-Value="Patient.Gender"
                   Placeholder="–"
                   Variant="Variant.Filled"
                   Clearable="true"
                   ClearIcon="@Icons.Material.Filled.Close"
                   Margin="Margin.Dense">
            <MudSelectItem T="string" Value="@("Male")">Male</MudSelectItem>
            <MudSelectItem T="string" Value="@("Female")">Female</MudSelectItem>
        </MudSelect>
    </div>;

    private RenderFragment MiniField(EyeField field) => @<div class="mini-field">
        <MudTextField T="string"
                      Label="@field.Label"
                      @bind-Value="field.Value"
                      Variant="Variant.Filled"
                      Margin="Margin.Dense"
                      Placeholder="–"
                      Clearable="true"
                      ClearIcon="@Icons.Material.Filled.Close"
                      Adornment="Adornment.End"
                      AdornmentText="@field.Unit" />
    </div>;

    private RenderFragment MiniText(string label, string value, Action<string> valueChanged) => @<div class="mini-field">
        <MudTextField T="string"
                      Label="@label"
                      Value="@value"
                      ValueChanged="@valueChanged"
                      Variant="Variant.Filled"
                      Placeholder="–"
                      Clearable="true"
                      ClearIcon="@Icons.Material.Filled.Close"
                      Margin="Margin.Dense" />
    </div>;

    private RenderFragment MiniSelect(string label, string value, Action<string> valueChanged, IEnumerable<string> options) => @<div class="mini-field">
        <MudSelect T="string"
                   Label="@label"
                   Value="@value"
                   ValueChanged="@valueChanged"
                   Variant="Variant.Filled"
                   Placeholder="–"
                   Clearable="true"
                   ClearIcon="@Icons.Material.Filled.Close"
                   Margin="Margin.Dense">
            @foreach (var option in options)
            {
                <MudSelectItem T="string" Value="@option">@option</MudSelectItem>
            }
        </MudSelect>
    </div>;

    private RenderFragment ToricSegment(EyeModel eye) => @<div class="toric-segment" role="group" aria-label="Toric mode">
        <button type="button"
                class="@($"toric-segment-button {(!eye.IsToric ? "active" : null)}")"
                aria-pressed="@(!eye.IsToric)"
                @onclick="@(() => eye.IsToric = false)">
            Non-toric
        </button>
        <button type="button"
                class="@($"toric-segment-button {(eye.IsToric ? "active" : null)}")"
                aria-pressed="@eye.IsToric"
                @onclick="@(() => eye.IsToric = true)">
            Toric
        </button>
    </div>;

    private RenderFragment EyePanel(string eyeCode, string side, EyeModel eye, bool forward) => @<MudPaper Elevation="0" Class="@($"eye-card {(forward ? "od-card" : "os-card")} {(eye.IsEnabled ? null : "disabled")}")">
        <div class="eye-header">
            <span class="eye-label">
                @if (forward)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                    <span>@eyeCode (@side)</span>
                }
                else
                {
                    <span>@eyeCode (@side)</span>
                    <MudIcon Icon="@Icons.Material.Filled.Visibility" Size="Size.Small" />
                }
            </span>

            <div class="eye-header-controls">
                @ToricSegment(eye)
                <button type="button"
                        class="@($"enable-btn {(eye.IsEnabled ? "active" : null)}")"
                        aria-pressed="@eye.IsEnabled"
                        @onclick="@(() => eye.IsEnabled = !eye.IsEnabled)">
                    @(eye.IsEnabled ? "ON" : "OFF")
                </button>
            </div>
        </div>

        <div class="eye-body @(eye.IsEnabled ? null : "disabled")">
            <div class="toggle-chip-row">
                @if (!eye.IsPostLvcRk)
                {
                    <button type="button"
                            class="toggle-chip"
                            aria-pressed="false"
                            @onclick="@(() => {
                                eye.IsPostLvcRk = true;
                                eye.PostLvcRkType = "M-LVC";
                            })">
                        Post LVC/RK
                    </button>
                }
                else
                {
                    <div class="compound-chip active">
                        <button type="button"
                                class="compound-chip-toggle"
                                aria-pressed="true"
                                @onclick="@(() => {
                                    eye.IsPostLvcRk = false;
                                    eye.PostLvcRkType = string.Empty;
                                })">
                            Post LVC/RK
                        </button>
                        <div class="compound-chip-options" role="group" aria-label="Post LVC/RK subtype">
                            @foreach (var option in PostLvcRkOptions)
                            {
                                <button type="button"
                                        class="@($"compound-chip-option {(eye.PostLvcRkType == option ? "active" : null)}")"
                                        aria-pressed="@(eye.PostLvcRkType == option)"
                                        @onclick="@(() => eye.PostLvcRkType = option)">
                                    @option
                                </button>
                            }
                        </div>
                    </div>
                }
                <button type="button"
                        class="@($"toggle-chip {(eye.IsKeratoconus ? "active" : null)}")"
                        aria-pressed="@eye.IsKeratoconus"
                        @onclick="@(() => eye.IsKeratoconus = !eye.IsKeratoconus)">
                    KC
                </button>
                <button type="button"
                        class="@($"toggle-chip {(eye.IsArgosSosAL ? "active" : null)}")"
                        aria-pressed="@eye.IsArgosSosAL"
                        @onclick="@(() => eye.IsArgosSosAL = !eye.IsArgosSosAL)">
                    SoS AL
                </button>
            </div>

            <div class="measurement-grid">
                @MiniField(eye.AL)
                @MiniField(eye.ACD)
                @MiniField(eye.LT)
                @MiniField(eye.CCT)
                @MiniField(eye.WTW)
                @MiniSelect("n", eye.Index, value => eye.Index = value, IndexOptions)
                @MiniField(eye.K1)
                @MiniField(eye.K2)
                <div class="mini-field-placeholder" aria-hidden="true"></div>

                @MiniSelect("IOL Manufacturer", eye.Manufacturer, value => eye.Manufacturer = value, ManufacturerOptions)
                @MiniSelect("IOL Model", eye.Iol, value => eye.Iol = value, IolOptions)
                @MiniText("Target Refraction", eye.TargetRefraction, value => eye.TargetRefraction = value)
            </div>

            <div class="constants-grid">
                @foreach (var item in Constants.Where(c => FormulaConfigs.Any(f => f.Name == c.FormulaName && f.IsEnabled)))
                {
                    <div class="constant-row">
                        <div class="constant-field">
                            <div class="constant-label">@item.Label</div>
                            <div class="constant-value-row">
                                <div class="constant-value @(string.IsNullOrWhiteSpace(item.Value) ? "empty" : null)">
                                    @(string.IsNullOrWhiteSpace(item.Value) ? "–" : item.Value)
                                </div>

                                @if (!string.IsNullOrWhiteSpace(item.Value))
                                {
                                    <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                   Size="Size.Small"
                                                   Class="field-clear-button"
                                                   OnClick="@(() => item.Value = string.Empty)" />
                                }
                            </div>
                        </div>

                        <MudIconButton Icon="@Icons.Material.Outlined.Info"
                                       Size="Size.Small"
                                       Color="Color.Secondary" />
                    </div>
                }
            </div>

            <div class="eye-nav @(forward ? "forward" : "back")">
                <MudIconButton Icon="@(forward ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ChevronLeft)"
                               Size="Size.Small"
                               Class="chevron-button" />
            </div>
        </div>
    </MudPaper>;

    public class ConstantItem
    {
        public ConstantItem(string label, string value, string formulaName)
        {
            Label = label;
            Value = value;
            FormulaName = formulaName;
        }

        public string Label { get; }
        public string Value { get; set; }
        public string FormulaName { get; }
    }

    public class FormulaConfig
    {
        public FormulaConfig(string name, bool isEnabled, bool nonToric, bool toric, bool mLvc, bool hLvc, bool rk, bool kc, bool sosAl)
        {
            Name = name;
            IsEnabled = isEnabled;
            NonToric = nonToric;
            Toric = toric;
            MLvc = mLvc;
            HLvc = hLvc;
            Rk = rk;
            Kc = kc;
            SosAl = sosAl;
        }

        public string Name { get; }
        public bool IsEnabled { get; set; }
        public bool NonToric { get; }
        public bool Toric { get; }
        public bool MLvc { get; }
        public bool HLvc { get; }
        public bool Rk { get; }
        public bool Kc { get; }
        public bool SosAl { get; }
    }

    public record BiomHistoryItem(string Initials, string PatientId, string Pin, string Expires);

    public record BiomLoadSummary(string SourceLabel, string SourceValue, string BiomPin, string Expires);

    public class PatientModel
    {
        public string Surgeon { get; set; } = "MR";
        public string Initials { get; set; } = string.Empty;
        public string Id { get; set; } = string.Empty;
        public string Age { get; set; } = string.Empty;
        public string Gender { get; set; } = string.Empty;
    }

    public class EyeModel
    {
        public EyeField AL { get; } = new("AL", "mm");
        public EyeField ACD { get; } = new("ACD", "mm");
        public EyeField LT { get; } = new("LT", "mm");
        public EyeField CCT { get; } = new("CCT", "µm");
        public EyeField WTW { get; } = new("WTW", "mm");
        public EyeField K1 { get; } = new("K1", "D");
        public EyeField K2 { get; } = new("K2", "D");
        public bool IsEnabled { get; set; } = true;
        public bool IsToric { get; set; }
        public bool IsKeratoconus { get; set; }
        public bool IsArgosSosAL { get; set; }
        public bool IsPostLvcRk { get; set; }
        public string PostLvcRkType { get; set; } = "M-LVC";
        public string Index { get; set; } = "1.3375";
        public string TargetRefraction { get; set; } = "-0.25";
        public string Manufacturer { get; set; } = "Alcon";
        public string Iol { get; set; } = "Clareon CNA0T0";
    }

    public class EyeField
    {
        public EyeField(string label, string unit)
        {
            Label = label;
            Unit = unit;
        }

        public string Label { get; }
        public string Value { get; set; } = string.Empty;
        public string Unit { get; }
    }

    private static readonly string[] IndexOptions = { "1.3375", "1.3320" };
    private static readonly string[] ManufacturerOptions = { "---", "Alcon", "Bausch + Lomb", "Johnson & Johnson", "Zeiss" };
    private static readonly string[] IolOptions = { "---", "Clareon CNA0T0", "AcrySof IQ SN60WF", "enVista MX60", "Tecnis DCB00" };
    private static readonly string[] PostLvcRkOptions = { "M-LVC", "H-LVC", "RK" };
}

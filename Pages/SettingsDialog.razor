@using System.Text.Json
@using escrsmockup.FormulaRules
@using MudBlazor

<MudDialog Class="settings-dialog">
    <DialogContent>
        <div class="settings-dialog-content">
            <h3 class="settings-section-title">Formulas</h3>
            <div class="formula-table-wrapper">
                <table class="formula-table">
                    <thead>
                        <tr>
                            <th class="col-enabled"></th>
                            <th class="col-formula"></th>
                            <th class="col-capability">Non-toric</th>
                            <th class="col-capability">Toric</th>
                            <th class="col-capability">M-LVC</th>
                            <th class="col-capability">H-LVC</th>
                            <th class="col-capability">RK</th>
                            <th class="col-capability">KC</th>
                            <th class="col-capability">SoS AL</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var formula in _workingRules.Formulas)
                        {
                            <tr>
                                <td class="col-enabled">
                                    <MudSwitch T="bool"
                                               @bind-Value="formula.Enabled"
                                               Color="Color.Primary" />
                                </td>
                                <td class="col-formula">@formula.Name</td>
                                <td class="col-capability">@CapabilityDot(SupportsToric(formula, false))</td>
                                <td class="col-capability">@CapabilityDot(SupportsToric(formula, true))</td>
                                <td class="col-capability">@CapabilityDot(SupportsPostLvc(formula, PostLvcRkType.MLvc))</td>
                                <td class="col-capability">@CapabilityDot(SupportsPostLvc(formula, PostLvcRkType.HLvc))</td>
                                <td class="col-capability">@CapabilityDot(SupportsPostLvc(formula, PostLvcRkType.RK))</td>
                                <td class="col-capability">@CapabilityDot(SupportsFlag(formula, combination => combination.Keratoconus, true))</td>
                                <td class="col-capability">@CapabilityDot(SupportsFlag(formula, combination => combination.SosAL, true))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="Reset">Reset</MudButton>
        <div style="flex-grow: 1;"></div>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public FormulaRuleSet FormulaRules { get; set; } = new();

    private FormulaRuleSet _workingRules = new();

    protected override void OnParametersSet()
    {
        _workingRules = CloneRules(FormulaRules);
    }

    private static FormulaRuleSet CloneRules(FormulaRuleSet rules)
    {
        var json = JsonSerializer.Serialize(rules, FormulaRuleJson.Options);
        return JsonSerializer.Deserialize<FormulaRuleSet>(json, FormulaRuleJson.Options) ?? new FormulaRuleSet();
    }

    private void Reset()
    {
        foreach (var formula in _workingRules.Formulas)
        {
            formula.Enabled = true;
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Save() => MudDialog.Close(DialogResult.Ok(_workingRules));

    private static RenderFragment CapabilityDot(bool supported) => @<span class="capability-dot @(supported ? "supported" : "unsupported")"></span>;

    private static bool SupportsToric(FormulaRule formula, bool isToric)
    {
        return formula.Combinations.Any(combination => !combination.Toric.HasValue || combination.Toric.Value == isToric);
    }

    private static bool SupportsPostLvc(FormulaRule formula, PostLvcRkType postLvcRk)
    {
        return formula.Combinations.Any(combination => combination.PostLvcRk.Count == 0 || combination.PostLvcRk.Contains(postLvcRk));
    }

    private static bool SupportsFlag(FormulaRule formula, Func<FormulaCombination, bool?> selector, bool value)
    {
        return formula.Combinations.Any(combination => !selector(combination).HasValue || selector(combination) == value);
    }
}
